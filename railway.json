{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "nixpacks"
    },
    "deploy": {
        "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
        "releaseCommand": "php artisan migrate --force && php artisan db:seed --force",
        "healthcheckPath": "/"
    }
}
